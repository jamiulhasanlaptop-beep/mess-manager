rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // AppState Validation
    function isValidAppState(data) {
      return data.keys().hasAll(['members', 'dailyEntries', 'deposits', 'otherExpenses'])
        && data.members is list
        && data.dailyEntries is map
        && data.deposits is list
        && data.otherExpenses is number;
    }

    match /messes/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
      
      // Subcollections
      match /members/{memberId} {
        allow read, write: if isOwner(userId);
      }
      match /dailyEntries/{date} {
        allow read, write: if isOwner(userId);
      }
      match /deposits/{depositId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }
  }
}
